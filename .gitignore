# Design/spec docs (local source of truth; do not commit)
docs/
design/

# Local environment — never commit secrets
.env
.env.local
.env.*
.envrc
*.pem
# Allow only non-secret example env files
!.env.local.example

# Next.js build output
.next/
out/
.vercel/

# Dependencies
node_modules/

# Yarn / pnpm
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# production
/build

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# TypeScript (generated by Next — optional to ignore)
*.tsbuildinfo
next-env.d.ts
